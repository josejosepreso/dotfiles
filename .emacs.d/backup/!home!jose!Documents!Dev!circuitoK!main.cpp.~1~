#include <iostream> // 
#include <sys/sem.h> // Llamado a semget, semaforos identificadores
#include <unistd.h> //
#include <sys/stat.h> //
#include <stdio.h> // Mensajes de error: perror()
#include <sys/wait.h> // Llamado a metodo wait
#include <string.h> // Cadenas de texto

// Se define cantidad de personas
#define N_ADULTOS 10
#define N_NINIOS 10

// Se definen cuantos procesos se crearan
#define N_TAQUILLA 1
#define N_SALA_ESPERA 3
#define N_PISTA 4
#define N_KART 2
#define N_MANTENIMIENTO 1

// Identificacion: horario de ninos o adultos
std::string persona = "Adulto";
bool TURNO_N = 0;

// Indices de los semaforos en el conjunto a crear
#define SEM_PISTA 0
#define SEM_TAQUILLA 1
#define SEM_SALAESPERA 2
#define SEM_MANTENIMIENTO 3
#define SEM_KART 4

union senum {
  int val;
};

int main(){

  pid_t pid;
  int sem;
  union senum arg;
  
  struct sembuf arriba = {0, 1, 0};
  struct sembuf abajo = {0, -1, 0};

  int r;
  
  // Creacion de conjunto de semaforos
  sem = semget(IPC_PRIVATE, 5, IPC_CREAT | IPC_EXCL | S_IRUSR | S_IWUSR);

  if(sem == -1){
    perror("Error creando semaforos");
  }

  arg.val = N_TAQUILLA;
  r = semctl(sem, SEM_TAQUILLA, SETVAL, arg);
  if(r == -1) {
    perror("Error inicializando el semaforo de taquilla");
  }

  arg.val = N_SALA_ESPERA;
  r = semctl(sem, SEM_SALAESPERA, SETVAL, arg);
  if(r == -1) {
    perror("Error inicializando el semaforo de sala de espera");
  }

  arg.val = N_PISTA;
  r = semctl(sem, SEM_PISTA, SETVAL, arg);
  if(r == -1) {
    perror("Error inicializando el semaforo de pista");
  }

  arg.val = N_KART;
  r = semctl(sem, SEM_KART, SETVAL, arg);
  if(r == -1) {
    perror("Error inicializando el semaforo de kart");
  }

  arg.val = N_MANTENIMIENTO;
  r = semctl(sem, SEM_MANTENIMIENTO, SETVAL, arg);
  if(r == -1) {
    perror("Error inicializando el semaforo de mantenimiento");
  }


  printf("========================\n");
  printf("==== Pista de karts ====\n");
  printf("========================\n\n");
  sleep(1);
  printf("==== Horario de adultos ====\n");
  printf("Realizando revision de las pistas...\n");
  sleep(2);
  srand((unsigned)time(0));
  switch(rand() % 2){
    case 0:
      printf("La pista presenta problemas. Realizando mantenimiento...\n");
      sleep(1);
      printf("Realizando limpieza general...\n");
      sleep(1);
      printf("Realizando reparaciones...\n");
      sleep(2);
      printf("Mantenimiento de pista concluido.\n\n");
      break;
    case 1:
      printf("Pista se encuentra disponible para recepcion de clientes.\n\n");
      break;
  }

  printf("Colocando obstaculos...\n");
  sleep(2);
  printf("Obstaculos colocados.\n\n");
  sleep(1);

  int i;
  for(i = 0; i < N_ADULTOS; i++) {
   
    pid = fork();
    if(pid == -1){
      printf("Error creando proceso hijo\n");
    }

    if(pid == 0){

      // Recepcion de personas en sala de tickets
      abajo.sem_num = SEM_TAQUILLA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      printf("Ingresa %s %i a taquilla...\n", persona.c_str(), i);
      sleep(1);
      printf("Ticket vendido a %s %i. Metodo de pago: ", persona.c_str(), i);
  
      srand((unsigned)time(0));
      switch(rand() % 2){
        case 0:
          printf("Tarjeta\n\n");
          break;
        case 1:
          printf("Efectivo\n\n");
          break;
      }


      arriba.sem_num = SEM_TAQUILLA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");


      // Recepcion de personas en sala de espera
      abajo.sem_num = SEM_SALAESPERA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      srand((unsigned)time(0));
      int tEspera = rand() % 5 + 1;

      printf("Ingresando %s %i a sala de espera...\n", persona.c_str(), i);
      sleep(1);
      printf("Ingresa %s %i a sala de espera\n\n", persona.c_str() ,i);
      sleep(tEspera);


      arriba.sem_num = SEM_SALAESPERA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");

      if(tEspera > 4){
        printf("Tiempo de espera de %s %i fue excedido. Abandona la sala de espera.\n\n", persona.c_str(), i);
      	return 0;
      }

      // Asignacion de kart a persona
      abajo.sem_num = SEM_KART;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      printf("Asignando kart a %s %i...\nRevisando el estado del kart...\n", persona.c_str(), i);
      sleep(2);


      srand((unsigned)time(0));
      switch(rand() % 3){
        case 0:
          printf("Kart %i requiere mantenimiento\n", i);

          abajo.sem_num = SEM_MANTENIMIENTO;
          r = semop(sem, &abajo, 1);
          if(r == -1) perror("");

	  printf("Realizando mantenimiento a kart %i...\n", i);
	  sleep(1);
	  printf("Realizando cambio de frenos a kart %i...\n", i);
	  sleep(1);
	  printf("Realizando cambio de neumaticos a kart %i...\n", i);
	  sleep(2);
	  printf("Mantenimiento de kart concluido. ");
          
	  arriba.sem_num = SEM_MANTENIMIENTO;
	  r = semop(sem, &arriba, 1);
	  if(r == -1) perror("");
	  
	  break;
        default:
          printf("Kart esta en buen estado. ");
          break;
      }

      printf("Se ha asignado kart de cilindrada alta a %s %i\n\n", persona.c_str(), i);

      arriba.sem_num = SEM_KART;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");




      // Ingresan personas a la pista
      abajo.sem_num = SEM_PISTA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      int t = rand() % 7 + 1;

      printf("Ingresando %s %i a la pista...\n", persona.c_str(), i);
      switch (rand() % 2){
        case 0:
          printf("Pista elegida por %s %i: Asfalto\n", persona.c_str(), i);
          break;
        case 1:
          printf("Pista elegida por %s %i: Todo terreno\n", persona.c_str(), i);
          break;  
      } 
      printf("Ingresa %s %i a pista. ", persona.c_str(), i);

      printf("%s %i esta corriendo...\n\n", persona.c_str(), i);
      sleep(t);
      printf("%s %i termina de correr. Tiempo recorrido: %i minutos. ", persona.c_str(), i, (t + 1) * 5);
      printf("%s %i devuelve el kart a estacionamiendo\n\n", persona.c_str(), i);



      arriba.sem_num = SEM_PISTA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");

      exit(0);
    }
  }

  pid = wait(&r);

  while( (pid != -1) || (pid == -1 && errno == EINTR)){
    pid = wait(&r);
  }


  sleep(2);
  printf("\n\n\n==== Horario de ninos ====\n");
  TURNO_N = 1;
  persona = "Nino";
  printf("Realizando revision de las pistas...\n");
  sleep(2);
  srand((unsigned)time(0));
  switch(rand() % 2){
    case 0:
      printf("La pista presenta problemas. Realizando mantenimiento...\n");
      sleep(3);
      printf("Mantenimiento de pista concluido.\n\n");
      break;
    case 1:
      printf("Pista se encuentra disponible para recepcion de clientes.\n\n");
      break;
  }

  printf("Colocando obstaculos...\n");
  sleep(2);
  printf("Obstaculos colocados.\n\n");


  for(i = 0; i < N_NINIOS; i++) {
    
    pid = fork();
    if(pid == -1){
      printf("Error creando proceso hijo\n");
    }

    if(pid == 0){

      abajo.sem_num = SEM_TAQUILLA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      printf("Ingresa %s %i a taquilla...\n", persona.c_str(), i);
      sleep(1);
      printf("Ticket vendido a %s %i. Metodo de pago: ", persona.c_str(), i);
  
      srand((unsigned)time(0));
      switch(rand() % 2){
        case 0:
          printf("Tarjeta\n\n");
          break;
        case 1:
          printf("Efectivo\n\n");
          break;
      }
      arriba.sem_num = SEM_TAQUILLA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");

      abajo.sem_num = SEM_SALAESPERA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      srand((unsigned)time(0));
      int tEspera = rand() % 5 + 1;

      printf("Ingresando %s %i a sala de espera...\n", persona.c_str(), i);
      sleep(1);
      printf("Ingresa %s %i a sala de espera\n\n", persona.c_str() ,i);
      sleep(tEspera);

      arriba.sem_num = SEM_SALAESPERA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");

      if(tEspera > 4){
        printf("Tiempo de espera de %s %i fue excedido. Abandona la sala de espera.\n\n", persona.c_str(), i);
      	return 0;
      }


      // Asignacion de kart a persona
      abajo.sem_num = SEM_KART;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      printf("Asignando kart a %s %i...\nRevisando el estado del kart...\n", persona.c_str(), i);
      sleep(2);


      srand((unsigned)time(0));
      switch(rand() % 3){
        case 0:
          printf("Kart %i requiere mantenimiento\n", i);

          abajo.sem_num = SEM_MANTENIMIENTO;
          r = semop(sem, &abajo, 1);
          if(r == -1) perror("");

	  printf("Realizando mantenimiento a kart %i...\n", i);
	  sleep(1);
	  printf("Realizando cambio de frenos a kart %i...\n", i);
	  sleep(1);
	  printf("Realizando cambio de neumaticos a kart %i...\n", i);
	  sleep(2);
	  printf("Mantenimiento de kart concluido. ");
          
	  arriba.sem_num = SEM_MANTENIMIENTO;
	  r = semop(sem, &arriba, 1);
	  if(r == -1) perror("");
	  
	  break;
        default:
          printf("Kart esta en buen estado. ");
          break;
      }

      printf("Se ha asignado kart de cilindrada baja a %s %i\n\n", persona.c_str(), i);

      arriba.sem_num = SEM_KART;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");




      abajo.sem_num = SEM_PISTA;
      r = semop(sem, &abajo, 1);
      if(r == -1) perror("");

      int t = rand() % 7 + 1;

      printf("Ingresando %s %i a la pista...\n", persona.c_str(), i);
      switch (rand() % 2){
        case 0:
          printf("Pista elegida por %s %i: Normal\n", persona.c_str(), i);
          break;
        case 1:
          printf("Pista elegida por %s %i: Todo terreno\n", persona.c_str(), i);
          break;  
      } 

      printf("Ingresa %s %i a pista. ", persona.c_str(), i);
      printf("%s %i esta corriendo...\n\n", persona.c_str(), i);
      sleep(t);
      printf("%s %i termina de correr. Tiempo recorrido: %i minutos. ", persona.c_str(), i, (t + 1) * 5);
      printf("%s %i devuelve el kart a estacionamiendo\n\n", persona.c_str(), i);

      arriba.sem_num = SEM_PISTA;
      r = semop(sem, &arriba, 1);
      if(r == -1) perror("");

      exit(0);
    }
  }

  pid = wait(&r);

  while( (pid != -1) || (pid == -1 && errno == EINTR)){
    pid = wait(&r);
  }

  r = semctl(sem, 0, IPC_RMID);
  if(r == -1){
    perror("");
  }

  printf("Fin.\n");
  return 0;
}
