~/.fehbg
emacs --daemon
while true; do
	
	DATE=$(date '+%Y %b %d (%a) %I:%M%p')
	MEM=$(free -h | awk '/^Mem:/ {print $3 "/" $2}')
	TEMP=$(sensors | awk '/^temp1/ {print $2}' | awk NR==1)
	# DISK=$(df -h | awk '/^\/dev\/sda3/ {print $3 "/" $2 " ("$5")"}')
	
	#SONG="..."
	#[ "$(mocp -Q %title)" ] && SONG=$(mocp -Q %song | cut -c -40) 
	#SSTATE=""
	#[ "$(mocp -Q %state)" ] && SSTATE=$(mocp -Q %state | sed "s/PLAY/пЃ‹\ /;s/PAUSE/пЃЊ\ /")

	UPDT=$(checkupdates | wc -l)
	
	#VOL=$(amixer get Master | grep -o "[0-9]*%")
	#ICON="о»Ё"
	#[ "$(amixer get Master | grep -o '\[on\]\|\[off\]')" = "[on]" ] && ICON="пЂЁ"
	
	BATT=$(cat /sys/class/power_supply/BAT1/capacity)
	BATTSTAT=""
	[ "$(cat /sys/class/power_supply/BAT1/status)" = "Charging" ] && BATTSTAT=" ^"

	# xsetroot -name "у°‡љ $UPDT | п’ј $TEMP | ої… $MEM | пЃі $DATE"
	xsetroot -name "у°‡љ $UPDT | п’ј $TEMP | ої… $MEM | пЃі $DATE | п‰„ $BATT%$BATTSTAT"
	# xsetroot -name "у°‡љ $UPDT | $ICON $VOL | $SSTATE$SONG | п’ј $TEMP | ої… $MEM | пЃі $DATE | п‰„ $BATT%$BATTSTAT"

	sleep 60
done &
exec dwm
